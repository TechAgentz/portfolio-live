# ------------------------------------------------------------------
# Supabase Postgres — from your Supabase project:
# Settings → Database → Connection string.
# DATABASE_URL  = pooled (Transaction) connection, port 6543, add ?pgbouncer=true
# DIRECT_URL    = direct connection, port 5432 (used for migrations / db push)
# ------------------------------------------------------------------
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------------
# NextAuth — https://next-auth.js.org/configuration/options
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
# NEXTAUTH_URL: your site URL (http://localhost:3000 in dev)
# ------------------------------------------------------------------
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ------------------------------------------------------------------
# Seeded admin account (used by `npm run db:seed` to create the first
# admin user). Change these before seeding.
# ------------------------------------------------------------------
ADMIN_EMAIL="admin@techagents.dev"
ADMIN_PASSWORD="change-this-password"
ADMIN_NAME="TechAgents Admin"

# ------------------------------------------------------------------
# Image uploads (admin) — Supabase Storage.
# SUPABASE_SERVICE_ROLE_KEY: Supabase → Settings → API → service_role key.
#   Server-side only (never exposed to the browser). Required for the
#   "upload from device" image picker in the admin.
# SUPABASE_URL: optional; defaults to the project URL in code.
# ------------------------------------------------------------------
SUPABASE_URL="https://bznwnfglwvktivjvfnbj.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
